rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // Helper Functions
    // ============================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function getProfile() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }
    
    function isRole(role) {
      let profile = getProfile();
      return profile != null && profile.user_type == role;
    }

    function isSuperAdmin() {
      let profile = getProfile();
      return profile != null && (profile.user_type == 'superadmin' || profile.is_superadmin == true);
    }

    function isConfirmedReferee(matchId) {
      let matchPath = /databases/$(database)/documents/matches/$(matchId);
      return exists(matchPath) && 
             get(matchPath).data.referee_id == request.auth.uid && 
             get(matchPath).data.referee_status == 'confirmed';
    }

    function noProtectedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['email', 'user_type', 'is_superadmin', 'is_active', 'created_at']);
    }

    // ============================================
    // Users collection
    // ============================================
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);
      
      allow update: if (isOwner(uid) && noProtectedFields())
                   || (isAuthenticated() && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers_count', 'updated_at']))
                   || (isAuthenticated() && 
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['matches_played', 'goals', 'assists', 'last_match_id', 'updated_at']));

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // Venues collection
    // ============================================
    match /venues/{venueId} {
      allow read: if isAuthenticated();
      allow create: if isRole('venue_owner') && request.resource.data.owner_id == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.owner_id == request.auth.uid || isSuperAdmin());
      allow delete: if isAuthenticated() && (resource.data.owner_id == request.auth.uid || isSuperAdmin());
    }

    // ============================================
    // Bookings collection
    // ============================================
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() 
        && (resource.data.owner_id == request.auth.uid || resource.data.user_id == request.auth.uid || isSuperAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() 
        && (resource.data.owner_id == request.auth.uid || resource.data.user_id == request.auth.uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // Teams collection
    // ============================================
    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (
          resource.data.manager_id == request.auth.uid
          || isSuperAdmin()
          || (
            request.resource.data.member_ids.hasAll(resource.data.member_ids)
            && request.auth.uid in request.resource.data.member_ids
            && request.resource.data.manager_id == resource.data.manager_id
            && request.resource.data.name == resource.data.name
          )
          || (
            // Referee or System updating stats
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['matches_played', 'wins', 'losses', 'draws', 'goals_for', 'goals_against', 'last_match_id', 'updated_at'])
          )
        );
      allow delete: if isAuthenticated() && (resource.data.manager_id == request.auth.uid || isSuperAdmin());
    }

    // ============================================
    // Matches collection
    // ============================================
    match /matches/{matchId} {
      allow read: if true; 
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (
          // 1. Managers/Admins
          resource.data.manager_id == request.auth.uid
          || (resource.data.away_manager_id != null && resource.data.away_manager_id == request.auth.uid)
          || isSuperAdmin()
          
          // 2. Confirmed Referee
          || (resource.data.referee_id == request.auth.uid && resource.data.referee_status == 'confirmed')
          
          // 3. Referee Basic Flow (Apply/Invite)
          || (request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['referee_id', 'referee_name', 'referee_status', 'updated_at', 'result']))

          // 4. Player Flow
          || (request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['confirmed_home', 'confirmed_away', 'players_confirmed', 'status', 'updated_at']))
        );
      allow delete: if isAuthenticated() && (resource.data.manager_id == request.auth.uid || isSuperAdmin());

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
    }

    // ============================================
    // Invitations collection
    // ============================================
    match /invitations/{invitationId} {
      allow read: if isAuthenticated() && (resource.data.sender_id == request.auth.uid || resource.data.receiver_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.sender_id == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.sender_id == request.auth.uid || (resource.data.receiver_id == request.auth.uid && request.resource.data.status in ['accepted', 'declined', 'pending']));
      allow delete: if isAuthenticated() && resource.data.sender_id == request.auth.uid;
    }

    // ============================================
    // Participations collection
    // ============================================
    match /participations/{participationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (
          resource.data.player_id == request.auth.uid
          || (
            exists(/databases/$(database)/documents/matches/$(resource.data.match_id)) &&
            (get(/databases/$(database)/documents/matches/$(resource.data.match_id)).data.manager_id == request.auth.uid ||
             get(/databases/$(database)/documents/matches/$(resource.data.match_id)).data.away_manager_id == request.auth.uid ||
             get(/databases/$(database)/documents/matches/$(resource.data.match_id)).data.referee_id == request.auth.uid)
          )
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['goals', 'assists', 'matches_played', 'updated_at']))
        );
      allow delete: if isAuthenticated() && (resource.data.player_id == request.auth.uid || (exists(/databases/$(database)/documents/matches/$(resource.data.match_id)) && get(/databases/$(database)/documents/matches/$(resource.data.match_id)).data.manager_id == request.auth.uid));
    }

    // ============================================
    // Others (Posts, Follows, etc.)
    // ============================================
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.author_id == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.author_id == request.auth.uid || isSuperAdmin());
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated() && (resource.data.author_id == request.auth.uid || isSuperAdmin());
      }
    }

    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.follower_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.follower_id == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated();
    }

    match /shortlists/{shortlistId} {
      allow read, delete: if isAuthenticated() && resource.data.manager_id == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.manager_id == request.auth.uid;
    }

    match /join_requests/{requestId} {
      allow create: if isAuthenticated() && request.resource.data.player_id == request.auth.uid;
      allow read: if isAuthenticated() && (resource.data.player_id == request.auth.uid || resource.data.manager_id == request.auth.uid);
      allow update: if isAuthenticated() && resource.data.manager_id == request.auth.uid;
    }

    match /trainings/{trainingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.manager_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.manager_id == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.manager_id == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendees', 'updated_at']));
    }

    match /player_ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && (request.resource.data.rated_by == request.auth.uid || resource.data.rated_by == request.auth.uid);
    }

    match /team_follows/{followId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAuthenticated() && (request.resource.data.follower_id == request.auth.uid || resource.data.follower_id == request.auth.uid);
    }

    match /teams/{teamId}/ghost_players/{ghostId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        get(/databases/$(database)/documents/teams/$(teamId)).data.manager_id == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        get(/databases/$(database)/documents/teams/$(teamId)).data.manager_id == request.auth.uid;
    }
  }
}
