rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // Helper functions
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function getUserType() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data.user_type : null;
    }

    function isRole(role) {
      return isAuthenticated() && getUserType() == role;
    }

    function isSuperAdmin() {
      return isRole('superadmin');
    }

    // Prevent modifying protected fields
    function noProtectedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['user_type', 'is_active', 'created_at', 'auth_providers']);
    }

    // ============================================
    // Users collection
    // ============================================
    match /users/{uid} {
      // Profiles are public but write is restricted
      allow read: if true;

      // Users can create their own profile at signup
      allow create: if isOwner(uid);

      // Users can update their own profile (except protected fields)
      // OR ANY authenticated user can update another user's followers_count 
      // when following/unfollowing (limited to just that field)
      allow update: if (isOwner(uid) && noProtectedFields())
                   || (isAuthenticated() && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers_count', 'updated_at']));

      // Only superadmin can delete users
      allow delete: if isSuperAdmin();
    }


    // ============================================
    // Venues collection
    // ============================================
    match /venues/{venueId} {
      // Anyone authenticated can read venues
      allow read: if isAuthenticated();

      // Only venue_owner can create
      allow create: if isAuthenticated()
        && request.resource.data.owner_id == request.auth.uid;

      // Only the venue owner can update their venue
      allow update: if isAuthenticated()
        && resource.data.owner_id == request.auth.uid;

      // Only venue owner or superadmin can delete
      allow delete: if isAuthenticated()
        && (resource.data.owner_id == request.auth.uid || isSuperAdmin());

      // Venue bookings subcollection
      match /bookings/{bookingId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated()
          && (resource.data.booked_by == request.auth.uid
              || get(/databases/$(database)/documents/venues/$(venueId)).data.owner_id == request.auth.uid);
      }
    }

    // ============================================
    // Teams collection (placeholder — expanded later)
    // ============================================
    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();

      allow update: if isAuthenticated()
        && (
          // Manager can edit everything
          resource.data.manager_id == request.auth.uid
          || (
            // Player can add themselves (self-join flow)
            // Ensure they don't remove anyone (security)
            request.resource.data.member_ids.hasAll(resource.data.member_ids)
            // Ensure they ADD themselves
            && request.auth.uid in request.resource.data.member_ids
            // Ensure they don't change the manager or team name
            && request.resource.data.manager_id == resource.data.manager_id
            && request.resource.data.name == resource.data.name
          )
        );

      allow delete: if isAuthenticated()
        && (resource.data.manager_id == request.auth.uid || isSuperAdmin());
    }

    // ============================================
    // Matches collection (placeholder — expanded later)
    // ============================================
    match /matches/{matchId} {
      allow read: if true; 
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (
          // 1. Home Manager (Match Creator) has full control
          resource.data.manager_id == request.auth.uid
          
          // 2. Away Manager can update match details (but NOT referee assignment)
          || (resource.data.away_manager_id != null && resource.data.away_manager_id == request.auth.uid && (
              !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['referee_id', 'referee_name', 'referee_status'])
          ))
          
          // 3. Referee-related updates (Application, Response, Reporting)
          || (
            // Check if the modified fields are restricted to referee/assignment related keys
            request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['referee_id', 'referee_name', 'referee_status', 'score_home', 'score_away', 'status', 'updated_at'])
            && (
              // Application: slot is empty, requester is referee, setting themselves to pending
              (resource.data.referee_status == 'none' && 
               request.resource.data.referee_id == request.auth.uid && 
               request.resource.data.referee_status == 'pending')
              
              // Response: requester is the assigned referee, responding to invitation or pending status
              || (resource.data.referee_id == request.auth.uid && 
                  (resource.data.referee_status == 'invited' || resource.data.referee_status == 'pending'))
              
              // Reporting: confirmed referee submitting scores
              || (resource.data.referee_id == request.auth.uid && 
                  resource.data.referee_status == 'confirmed')
            )
            // Ensure they don't change core match fields (teams, date, venue)
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['home_team_id', 'away_team_id', 'manager_id', 'date', 'time', 'venue_name', 'venue_city'])
          )

          // 4. Player-related counter updates (any authenticated user can update these via participation flow)
          || (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['confirmed_home', 'confirmed_away', 'players_confirmed', 'status', 'updated_at'])
          )
        );
      allow delete: if isAuthenticated() && resource.data.manager_id == request.auth.uid;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
    }

    // ============================================
    // Invitations collection
    // ============================================
    match /invitations/{invitationId} {
      allow read: if isAuthenticated()
        && (resource.data.sender_id == request.auth.uid
            || resource.data.receiver_id == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.sender_id == request.auth.uid;
      allow update: if isAuthenticated()
        && (
          resource.data.sender_id == request.auth.uid
          || (
            resource.data.receiver_id == request.auth.uid
            && request.resource.data.status in ['accepted', 'declined', 'pending']
            && request.resource.data.sender_id == resource.data.sender_id
            && request.resource.data.team_id == resource.data.team_id
          )
        );
      allow delete: if isAuthenticated()
        && resource.data.sender_id == request.auth.uid;
    }

    // ============================================
    // Participations collection
    // ============================================
    match /participations/{participationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (
          // Player can respond
          resource.data.player_id == request.auth.uid
          // OR manager of the match can update (e.g. cancel)
          || (
            exists(/databases/$(database)/documents/matches/$(resource.data.match_id)) &&
            (get(/databases/$(database)/documents/matches/$(resource.data.match_id)).data.manager_id == request.auth.uid ||
             get(/databases/$(database)/documents/matches/$(resource.data.match_id)).data.away_manager_id == request.auth.uid)
          )
        );
      allow delete: if isAuthenticated() && (
        resource.data.player_id == request.auth.uid ||
        (exists(/databases/$(database)/documents/matches/$(resource.data.match_id)) &&
         get(/databases/$(database)/documents/matches/$(resource.data.match_id)).data.manager_id == request.auth.uid)
      );
    }

    // ============================================
    // Feed / Posts collection
    // ============================================
    match /posts/{postId} {
      allow read: if true; // Public feed
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && resource.data.author_id == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource.data.author_id == request.auth.uid || isSuperAdmin());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated()
          && (resource.data.author_id == request.auth.uid || isSuperAdmin());
      }
    }

    // ============================================
    // Follows collection
    // ============================================
    match /follows/{followId} {
      allow read, list: if true;
      allow create: if isAuthenticated()
        && request.resource.data.follower_id == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.follower_id == request.auth.uid;
    }


    // ============================================
    // Notifications collection
    // ============================================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
        && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && resource.data.user_id == request.auth.uid;
    }

    // ============================================
    // Shortlists collection (manager mercato)
    // ============================================
    match /shortlists/{shortlistId} {
      allow read, delete: if isAuthenticated()
        && resource.data.manager_id == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.manager_id == request.auth.uid;
    }

    // ============================================
    // Join Requests collection (player → team)
    // ============================================
    match /join_requests/{requestId} {
      allow create: if isAuthenticated()
        && request.resource.data.player_id == request.auth.uid;
      allow read: if isAuthenticated()
        && (resource.data.player_id == request.auth.uid
            || resource.data.manager_id == request.auth.uid);
      allow update: if isAuthenticated()
        && resource.data.manager_id == request.auth.uid;
    }

    // ============================================
    // Trainings collection
    // ============================================
    match /trainings/{trainingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.manager_id == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.manager_id == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['attendees', 'updated_at'])
      );
      allow delete: if isAuthenticated()
        && resource.data.manager_id == request.auth.uid;
    }

    // ============================================
    // Player Ratings collection
    // ============================================
    match /player_ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.rated_by == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.rated_by == request.auth.uid;
    }

    // ============================================
    // Team Follows collection
    // ============================================
    match /team_follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.follower_id == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.follower_id == request.auth.uid;
    }
  }
}
