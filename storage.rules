rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // User profile assets
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Post media
    match /posts/{postId}/media/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Team assets: logo, banner, gallery
    match /teams/{teamId}/logo/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /teams/{teamId}/banner/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /teams/{teamId}/gallery/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Competition assets: logo, banner, and per-match banners. Public read;
    // any authenticated user may write (organizer role is enforced by the
    // Firestore rules that gate the competition docs these images belong to).
    match /competitions/{cid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Catch-all deny
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
